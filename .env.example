# App
ENV=development
APP_HOST=127.0.0.1
APP_PORT=3000
TIMEZONE=America/Mexico_city
FRONTEND_URL=http://localhost:5173

# Security
SECRET_KEY=change_me_in_production
JWT_ISSUER=https://auth.tudominio.com
JWT_EXPIRATION_SECONDS=3600
RESET_TOKEN_EXPIRATION_HOURS=2

# JWT Keys — local (development)
# Paths to RSA PEM files. Generate with: ./scripts/generate_keys.sh
JWT_PRIVATE_KEY_PATH=.secrets/private.pem
JWT_PUBLIC_KEY_PATH=.secrets/public.pem

# Admin seed (only created if user doesn't exist)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_in_production
ADMIN_NAME=Admin

# JWT Keys — AWS Secrets Manager (production)
# When these are set, local key paths are ignored.
# AWS_JWT_PRIVATE_KEY_SECRET=auth/jwt/private-key
# AWS_JWT_PUBLIC_KEY_SECRET=auth/jwt/public-key
# AWS_REGION=us-east-1

# Database
DATABASE_HOST=
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_PORT=5432
DATABASE_NAME=
DATABASE_SCHEMA=
DATABASE_MAX_CONNECTIONS=10

# Redis
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Mail
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@example.com
MAIL_FROM_NAME=

# Workers
WORKER_CONCURRENCY=4
WORKER_QUEUE=default
WORKER_TIMEOUT_SECONDS=30

# WebSockets
WS_MAX_CONNECTIONS=1000
WS_HEARTBEAT_INTERVAL_SECONDS=30
WS_TIMEOUT_SECONDS=60

# HTTP Client
HTTP_CLIENT_TIMEOUT_SECONDS=30
HTTP_CLIENT_MAX_RETRIES=3

# Storage
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_ENDPOINT=

# Logging
RUST_LOG=rust_template=debug,tower_http=debug
