# .env.example

# App
ENV=development
HOST=0.0.0.0:3000
TIMEZONE=America/Mexico_city

# Security
SECRET_KEY=change_me_in_production
JWT_SECRET=change_me_in_production
JWT_EXPIRATION_SECONDS=3600

# Database
DATABASE_URL=postgres://user:password@localhost:5432/rust_template
DATABASE_MAX_CONNECTIONS=10
DATABASE_MIN_CONNECTIONS=2
DATABASE_CONNECT_TIMEOUT_SECONDS=5
DATABASE_IDLE_TIMEOUT_SECONDS=600

# Redis
REDIS_URL=redis://localhost:6379
REDIS_MAX_CONNECTIONS=10
REDIS_TIMEOUT_SECONDS=5

# Mail
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=no-reply@example.com
MAIL_PASSWORD=change_me_in_production
MAIL_FROM=no-reply@example.com
MAIL_FROM_NAME=Rust Template

# Workers
WORKER_CONCURRENCY=4
WORKER_QUEUE=default
WORKER_TIMEOUT_SECONDS=30

# WebSockets
WS_MAX_CONNECTIONS=1000
WS_HEARTBEAT_INTERVAL_SECONDS=30
WS_TIMEOUT_SECONDS=60

# HTTP Client
HTTP_CLIENT_TIMEOUT_SECONDS=30
HTTP_CLIENT_MAX_RETRIES=3

# Storage
STORAGE_BUCKET=rust-template
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=change_me_in_production
STORAGE_SECRET_KEY=change_me_in_production
STORAGE_ENDPOINT=https://s3.amazonaws.com

# Logging
RUST_LOG=rust_template=debug,tower_http=debug