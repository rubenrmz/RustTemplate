# .env.example

# App
ENV=development
HOST=0.0.0.0:3000
TIMEZONE=America/Mexico_city
FRONTEND_URL=http://localhost:5173

# Security
SECRET_KEY=change_me_in_production
JWT_ISSUER=https://auth.tudominio.com
JWT_EXPIRATION_SECONDS=3600
RESET_TOKEN_EXPIRATION_HOURS=2

# JWT Keys — local (development)
# Paths to RSA PEM files. Generate with: ./scripts/generate_keys.sh
JWT_PRIVATE_KEY_PATH=private.pem
JWT_PUBLIC_KEY_PATH=public.pem

# JWT Keys — AWS Secrets Manager (production)
# When these are set, local key paths are ignored.
# AWS_JWT_PRIVATE_KEY_SECRET=auth/jwt/private-key
# AWS_JWT_PUBLIC_KEY_SECRET=auth/jwt/public-key
# AWS_REGION=us-east-1

# Database
DATABASE_USER=user
DATABASE_PASSWORD=password
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=rust_template
DATABASE_SCHEMA=public
DATABASE_MAX_CONNECTIONS=10

# Redis
REDIS_URL=redis://localhost:6379
REDIS_MAX_CONNECTIONS=10
REDIS_TIMEOUT_SECONDS=5

# Mail
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=no-reply@example.com
MAIL_PASSWORD=change_me_in_production
MAIL_FROM=no-reply@example.com
MAIL_FROM_NAME=Rust Template

# Workers
WORKER_CONCURRENCY=4
WORKER_QUEUE=default
WORKER_TIMEOUT_SECONDS=30

# WebSockets
WS_MAX_CONNECTIONS=1000
WS_HEARTBEAT_INTERVAL_SECONDS=30
WS_TIMEOUT_SECONDS=60

# HTTP Client
HTTP_CLIENT_TIMEOUT_SECONDS=30
HTTP_CLIENT_MAX_RETRIES=3

# Storage
STORAGE_BUCKET=rust-template
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=change_me_in_production
STORAGE_SECRET_KEY=change_me_in_production
STORAGE_ENDPOINT=https://s3.amazonaws.com

# Logging
RUST_LOG=rust_template=debug,tower_http=debug
